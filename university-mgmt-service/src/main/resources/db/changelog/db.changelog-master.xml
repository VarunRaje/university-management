<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-students" author="Varun Deshpande">
        <createTable tableName="students">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_number" type="VARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="date_of_birth" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="students" indexName="idx_students_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-courses" author="Varun Deshpande">
        <createTable tableName="courses">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="title" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="credits" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="department" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="courses" indexName="idx_courses_department">
            <column name="department"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-enrollments" author="Varun Deshpande">
        <createTable tableName="enrollments">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="course_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="semester" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)" defaultValue="ENROLLED">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="enrollments"
            baseColumnNames="student_id"
            constraintName="fk_enrollments_student"
            referencedTableName="students"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="enrollments"
            baseColumnNames="course_id"
            constraintName="fk_enrollments_course"
            referencedTableName="courses"
            referencedColumnNames="id"/>

        <addUniqueConstraint
            tableName="enrollments"
            columnNames="student_id, course_id, semester"
            constraintName="uk_enrollments_student_course_semester"/>

        <createIndex tableName="enrollments" indexName="idx_enrollments_student_id">
            <column name="student_id"/>
        </createIndex>

        <createIndex tableName="enrollments" indexName="idx_enrollments_course_id">
            <column name="course_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-add-addresses-student" author="Varun Deshpande">
        <addColumn tableName="students">
            <column name="permanant_address" type="jsonb">
                <constraints nullable="true"/>
            </column>
            <column name="current_address" type="jsonb">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
